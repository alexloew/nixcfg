// Base rule: clip to geometry + default opacity for all windows
window-rule {
    clip-to-geometry true
    opacity 0.95
}

// Inactive windows: reduced opacity
window-rule {
    match is-active=false
    opacity 0.90
}

// Terminals: match active baseline opacity
window-rule {
    match app-id=r"^com\.mitchellh\.ghostty$"
    match app-id=r"^Alacritty$"
    match app-id=r"^kitty$"
    match app-id=r"^foot$"
    opacity 0.95
}

// Browsers and media: fully opaque
window-rule {
    match app-id=r"^google-chrome$"
    match app-id=r"^firefox$"
    match app-id=r"^Slack$"
    match app-id=r"^mpv$"
    match app-id=r"^vlc$"
    opacity 1.0
}

// Chrome + Ghostty: open maximized (configure-displays focuses correct output before spawning)
window-rule {
    match app-id=r"^google-chrome$"
    match app-id=r"^com\.mitchellh\.ghostty$"
    open-maximized true
}

// Slack: open maximized on 27-inch (configure-displays focuses before spawn)
window-rule {
    match app-id=r"^Slack$"
    open-maximized true
}
